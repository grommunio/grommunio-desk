{
  "compilerOptions": {
    "target": "esnext",
    "module": "es2020",
    "moduleResolution": "bundler",
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "esModuleInterop": true,
    "jsx": "react",
    "plugins": [{"name": "typescript-plugin-css-modules"}],
    "baseUrl": ".",
    "paths": {
      "@utils/*": ["src/main/utils/*", "src/renderer/utils/*"],
    }
  },
  "include": [
    "src"
  ]
}
