{
  "name": "grommunio-desk",
  "version": "1.0.0",
  "main": "./main.js",
  "scripts": {
    "build": "cross-env NODE_ENV=develop run-p build:*",
    "prod": "cross-env NODE_ENV=production run-p build:*",
    "build:main": "webpack --config ./webpack.config.main.js",
    "build:renderer": "webpack --config ./webpack.config.renderer.js",
    "start": "electron ./build/main.js",
    "dev": "run-p dev:webpack dev:electron",
    "dev:webpack": "webpack-dev-server --hot --config ./webpack.config.renderer.js",
    "dev:build": "cross-env NODE_ENV=develop run-p build:main",
    "dev:electron": "npm run dev:build && wait-on http://localhost:8080/main.html && npm run start",
    "eslint": "eslint",
    "tsc": "tsc --noEmit",
    "test": "run-p eslint tsc",
    "prepare": "husky"
  },
  "author": {
    "name": "grommunio GmbH",
    "email": "dev@grommunio.com",
    "url": "https://grommunio.com"
  },
  "license": "MIT",
  "description": "Desktop App for grommunio",
  "homepage": "https://grommunio.com",
  "repository": {
    "url": "https://github.com/grommunio"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@babel/preset-typescript": "^7.28.5",
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "babel-loader": "^10.0.0",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "electron": "^38.2.0",
    "electron-reloader": "^1.2.3",
    "eslint": "^9.37.0",
    "eslint-plugin-license-header": "^0.8.0",
    "eslint-webpack-plugin": "^5.0.2",
    "html-webpack-plugin": "^5.6.4",
    "husky": "^9.1.7",
    "mini-css-extract-plugin": "^2.9.4",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "wait-on": "^9.0.1",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
