{
  "name": "grommunio-desk",
  "productName": "grommunio Desk",
  "version": "1.1.0",
  "description": "Desktop client for grommunio",
  "main": ".webpack/main",
  "private": true,
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make --skip-package",
    "make.msix": "electron-forge make --skip-package --targets msix",
    "make.squirrel": "electron-forge make --skip-package --targets squirrel",
    "publish": "electron-forge publish",
    "prepare": "husky",
    "lint": "eslint .",
    "tsc": "tsc --noEmit",
    "test": "run-p lint tsc",
    "generate-msix-manifest": "tsx ./scripts/generateMsixManifest.ts"
  },
  "keywords": [
    "Office",
    "Email",
    "InstantMessaging"
  ],
  "author": {
    "name": "grommunio GmbH",
    "email": "dev@grommunio.com",
    "url": "https://grommunio.com"
  },
  "homepage": "https://grommunio.com",
  "repository": {
    "url": "https://github.com/grommunio/grommunio-desk"
  },
  "license": "AGPL-3.0-only",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-webpack": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/webpack-asset-relocator-loader": "1.7.3",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.11.0",
    "dotenv": "^17.4.1",
    "electron": "41.0.2",
    "electron-log": "^5.4.3",
    "eslint": "^9.39.4",
    "eslint-plugin-license-header": "^0.9.0",
    "fork-ts-checker-webpack-plugin": "^7.3.0",
    "husky": "^9.1.7",
    "i18next": "^25.10.10",
    "node-loader": "^2.1.0",
    "npm-run-all": "^4.1.5",
    "react-i18next": "^16.6.6",
    "style-loader": "^3.3.4",
    "ts-loader": "^9.5.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  }
}
