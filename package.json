{
  "name": "grommunio-desk",
  "version": "1.0.0",
  "main": "dist/electron.js",
  "scripts": {
    "build": "run-p build:*",
    "build:main": "webpack --config ./webpack.config.dev.main.js",
    "build:renderer": "webpack --config ./webpack.config.dev.renderer.js",
    "prod": "run-p prod:*",
    "prod:main": "webpack --config ./webpack.config.prod.main.js",
    "prod:renderer": "webpack --config ./webpack.config.prod.renderer.js",
    "start": "electron ./dist/electron.js",
    "dev": "npm run build:main && run-p dev:*",
    "dev:webpack": "webpack-dev-server --hot --config ./webpack.config.dev.renderer.js",
    "dev:electron": "wait-on http://localhost:8080 && electron ./dist/electron.js",
    "eslint": "eslint",
    "tsc": "tsc --noEmit",
    "test": "run-p eslint tsc",
    "prepare": "husky"
  },
  "author": {
    "name": "grommunio GmbH",
    "email": "dev@grommunio.com",
    "url": "https://grommunio.com"
  },
  "license": "MIT",
  "description": "Desktop App for grommunio",
  "homepage": "https://grommunio.com",
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@stylistic/eslint-plugin": "^5.4.0",
    "@types/react": "^19.1.16",
    "@types/react-dom": "^19.1.9",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^7.0.2",
    "electron": "^38.2.0",
    "electron-reloader": "^1.2.3",
    "eslint": "^9.37.0",
    "eslint-webpack-plugin": "^5.0.2",
    "html-webpack-plugin": "^5.6.4",
    "husky": "^9.1.7",
    "mini-css-extract-plugin": "^2.9.4",
    "npm-run-all": "^4.1.5",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.0",
    "typescript-plugin-css-modules": "^5.2.0",
    "wait-on": "^9.0.1",
    "webpack": "^5.102.0",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  }
}
