{
  "mainWindow": {
    "startView": {
      "text": {
        "description": "Enter your grommunio server name and URL to continue."
      },
      "button": {
         "submit": "Submit"
      },
      "input": {
        "url": {
          "feedback": {
            "valid": {
              "version": "Version {{system.version}}",
              "web": "Web Server verified",
              "chat": "Chat Server verified"
            },
            "invalidFormat": "Please enter a valid https:// URL.",
            "invalidServer": "Invalid server URL."
          }
        },
        "name": {
          "placeholder": "Your server name",
          "feedback": {
            "invalidFormat": "Please enter a valid server name."
          }
        }
      }
    },
    "titleBarView": {
      "servers": "Servers",
      "addServer": "Add server"
    },
    "dialogView": {
      "title": {
        "loadFailed": "Loading failed",
        "removeServer": "Remove server?"
      },
      "text": {
        "loadFailed": "Loading of {{url}} failed.",
        "removeServer": "Do you really want to remove the server \"{{server.name}}\"?"
      },
      "button": {
        "returnToStartPage": "Return",
        "cancel": "Cancel",
        "removeServer": "Remove"
      }
    }
  }
